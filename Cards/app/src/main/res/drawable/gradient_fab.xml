<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/app_ripple">

    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="#ffffff"/>
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="@color/app_accent"
                android:endColor="@color/app_accent_light"
                android:angle="135"
                android:type="linear"/>
        </shape>
    </item>

</ripple>